# Copy this file to .env and replace both secrets before starting the stack.
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DB_PASSWORD=replace-with-a-strong-database-password

# Raspberry Pi address or DNS name. Separate multiple values with commas.
DJANGO_ALLOWED_HOSTS=192.168.1.50,supermarket.local,localhost,127.0.0.1

# Add the public HTTPS URL when placing the app behind a reverse proxy.
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_SECURE_COOKIES=0

DB_NAME=price_compare
DB_USER=supermarket_app
WEB_PORT=8080
CELERY_CONCURRENCY=2
CELERY_RESULT_EXPIRES=3600
PRICE_MAX_AGE_HOURS=48
